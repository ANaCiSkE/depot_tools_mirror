import os
import sys
import subprocess
import tomllib
from pathlib import PurePath


def match_pattern(file_path: str, config_dir: str, pattern: str) -> bool:
    """Checks if file_path matches a given Ruff pattern (glob or prefix).

    Args:
        file_path: Absolute or relative path to the target file being evaluated.
        config_dir: Directory containing the configuration file where the pattern was defined.
        pattern: Ruff glob or directory prefix pattern from include/exclude lists.

    Returns:
        True if the file matches the pattern, False otherwise.
    """
    # Unsupported by ruff pattern, so we don't support it either.
    if "**" in pattern:
        return False

    pattern_clean = os.path.normpath(pattern)
    # Strip leading slashes/backslashes so os.path.join does not treat anchored patterns
    # (like "/foo.py") as absolute filesystem roots and discard config_dir.
    pattern_rel = pattern_clean.lstrip(r"\/")
    abs_pattern = os.path.join(
        config_dir, pattern_rel) if config_dir != "." else pattern_rel

    # 1. Directory prefix match: os.path.relpath checks if file_path is inside abs_pattern directory
    # (e.g., pattern "third_party" matches any file inside "third_party/...").
    try:
        rel = os.path.relpath(file_path, abs_pattern)
        if not rel.startswith("..") and not os.path.isabs(rel):
            return True
    except ValueError:
        pass

    # 2. Filename glob match: if pattern has no path separators (e.g., "*.py"), match against filename anywhere in tree.
    if "/" not in pattern_clean and "\\" not in pattern_clean:
        if PurePath(file_path).match(pattern_clean):
            return True

    # 3. Simple path glob match: if pattern has path separators (e.g., "foo/*.py"), match against relative path from config_dir.
    if "/" in pattern_clean or "\\" in pattern_clean:
        if PurePath(file_path).match(abs_pattern):
            return True

    return False


def ruff_should_format(file_path: str, config_dir: str, config_bytes: bytes,
                       is_pyproject: bool) -> bool:
    """Determines if a file should be formatted by Ruff based on TOML config.

    Args:
        file_path: Path to the target file being formatted.
        config_dir: Directory containing the configuration file.
        config_bytes: Raw byte content of the TOML configuration file.
        is_pyproject: True if the config file is pyproject.toml, False for ruff.toml/.ruff.toml.

    Returns:
        True if Ruff should format the file (included and not excluded),
        False otherwise. If file is unreadable opt for YAPF.
    """
    try:
        cfg = tomllib.loads(config_bytes.decode("utf-8"))
    except Exception:
        # If TOML is malformed, default to Ruff to let Ruff report syntax error
        return True

    # Backported logic from Ruff to parse the TOML file.
    target = cfg.get("tool", {}).get("ruff", {}) if is_pyproject else cfg
    excludes = [
        *target.get("exclude", []),
        *target.get("extend-exclude", []),
        *target.get("format", {}).get("exclude", []),
    ]
    includes = [
        *target.get("include", []),
        *target.get("extend-include", []),
    ]

    # 1. Check inclusion if explicitly defined. Note: bool() ensures an empty list [] in TOML
    # is treated as False (no include filter), whereas a non-empty list actively filters formatting.
    if bool(target.get("include")):
        if not any(
                match_pattern(file_path, config_dir, pat) for pat in includes):
            return False

    # 2. Check exclusion
    for pattern in excludes:
        if match_pattern(file_path, config_dir, pattern):
            return False

    return True


def should_use_ruff(target_path: str) -> bool:
    """Determines whether to format target_path using Ruff or fall back to YAPF.

    Args:
        target_path: Path to the file or directory being formatted.

    Returns:
        True if covered by a valid Ruff configuration, False otherwise (fallback to YAPF).
    """
    abs_target = os.path.abspath(target_path)
    search_dir = os.path.dirname(abs_target) if (
        os.path.isfile(abs_target)
        or not os.path.exists(abs_target)) else abs_target

    # Traverse upwards from the target file's directory. Child directories are never evaluated
    # because Ruff configs only apply to files within their own directory tree or below.
    while True:
        # Check .ruff.toml first (highest precedence in same dir)
        dot_ruff = os.path.join(search_dir, ".ruff.toml")
        if os.path.isfile(dot_ruff):
            try:
                with open(dot_ruff, "rb") as f:
                    if ruff_should_format(abs_target, search_dir, f.read(),
                                          False):
                        return True
            except Exception:
                return False

        # Check ruff.toml second
        ruff_toml = os.path.join(search_dir, "ruff.toml")
        if os.path.isfile(ruff_toml):
            try:
                with open(ruff_toml, "rb") as f:
                    if ruff_should_format(abs_target, search_dir, f.read(),
                                          False):
                        return True
            except Exception:
                return False

        # Check pyproject.toml third
        pyproject = os.path.join(search_dir, "pyproject.toml")
        if os.path.isfile(pyproject):
            try:
                with open(pyproject, "rb") as f:
                    content_bytes = f.read()
                content_str = content_bytes.decode("utf-8", errors="ignore")
                if "[tool.ruff]" in content_str:
                    if "[tool.yapf]" in content_str or "[tool.black]" in content_str or "[tool.pyink]" in content_str:
                        pass
                    elif ruff_should_format(abs_target, search_dir,
                                            content_bytes, True):
                        if os.path.exists(
                                os.path.join(search_dir, ".style.yapf")):
                            return False
                        return True
            except Exception:
                pass

        # Check for explicit yapf config
        if os.path.exists(os.path.join(search_dir, ".style.yapf")):
            return False

        parent_dir = os.path.dirname(search_dir)
        if parent_dir == search_dir:
            break
        search_dir = parent_dir

    return False


def has_yapf_config(target_path: str) -> bool:
    """Determines whether a YAPF formatting configuration governs target_path.

    Args:
        target_path: Path to the file or directory being evaluated.

    Returns:
        True if .style.yapf or pyproject.toml with [tool.yapf] exists in any
        ancestor directory, False otherwise.
    """
    abs_target = os.path.abspath(target_path)
    search_dir = (os.path.dirname(abs_target) if
                  (os.path.isfile(abs_target)
                   or not os.path.exists(abs_target)) else abs_target)

    while True:
        if os.path.isfile(os.path.join(search_dir, ".style.yapf")):
            return True

        pyproject = os.path.join(search_dir, "pyproject.toml")
        if os.path.isfile(pyproject):
            try:
                with open(pyproject, "rb") as f:
                    content = f.read().decode("utf-8", errors="ignore")
                if "[tool.yapf]" in content:
                    return True
            except Exception:
                pass

        parent_dir = os.path.dirname(search_dir)
        if parent_dir == search_dir:
            break
        search_dir = parent_dir

    return False


def translate_args(args: list[str]) -> list[str]:
    """Translates Ruff command-line arguments into YAPF command-line arguments.

    Args:
        args: List of command-line arguments passed to the ruff wrapper.

    Returns:
        List of translated arguments suitable for invoking YAPF.
    """
    yapf_args = []
    has_diff = False
    has_stdin = False
    files = []

    i = 0
    while i < len(args):
        arg = args[i]
        # YAPF takes options and files directly without a subcommand, so strip "format".
        if arg == "format":
            i += 1
            continue
        # Ruff uses --range start:col-end:col; YAPF uses --line start-end (line numbers only, no columns).
        elif arg == "--range":
            val = args[i + 1]
            try:
                parts = val.split("-")
                start_line = parts[0].split(":")[0]
                end_line = parts[1].split(":")[0]
                yapf_args.extend(["--line", f"{start_line}-{end_line}"])
            except Exception:
                yapf_args.extend(["--range", val])
            i += 2
        # Handle equals-separated --range=start:col-end:col (e.g. from fmtserver or editors).
        elif arg.startswith("--range="):
            val = arg.split("=", 1)[1]
            try:
                parts = val.split("-")
                start_line = parts[0].split(":")[0]
                end_line = parts[1].split(":")[0]
                yapf_args.extend(["--line", f"{start_line}-{end_line}"])
            except Exception:
                yapf_args.append(arg)
            i += 1
        elif arg == "--diff":
            has_diff = True
            yapf_args.append(arg)
            i += 1
        elif arg == "-":
            has_stdin = True
            yapf_args.append(arg)
            i += 1
        elif arg.startswith("-"):
            # Pass through other flags (like --stdin-filename)
            yapf_args.append(arg)
            i += 1
        else:
            files.append(arg)
            yapf_args.append(arg)
            i += 1

    # Ruff formats files in-place by default; YAPF prints to stdout unless -i is explicitly passed.
    if files and not has_diff and not has_stdin:
        yapf_args.append("-i")

    return yapf_args


def main() -> int:
    """Main entrypoint for the depot_tools ruff wrapper.

    Returns:
        Exit code of the invoked formatter subprocess.
    """
    args = sys.argv[1:]

    # Determine target path for config detection
    target_path = os.getcwd()
    for i, arg in enumerate(args):
        if arg.startswith("--stdin-filename="):
            target_path = arg.split("=", 1)[1]
            break
        elif arg == "--stdin-filename" and i + 1 < len(args):
            target_path = args[i + 1]
            break
        elif not arg.startswith("-") and arg != "format":
            target_path = arg
            break

    if should_use_ruff(target_path):
        # Run Ruff from the vpython environment
        # sys.executable points to the vpython python interpreter
        cmd = [sys.executable, "-m", "ruff"] + args
        return subprocess.call(cmd)
    else:
        # Before attempting YAPF as a backoff, ascertain that a YAPF formatter/config
        # is present. If the file was rejected by Ruff (e.g. excluded in ruff.toml)
        # and no YAPF config governs the directory, return 0 (no-op).
        if not has_yapf_config(target_path):
            return 0

        # Fallback to YAPF
        # Find yapf wrapper in the same directory as this script
        depot_tools_dir = os.path.dirname(os.path.abspath(__file__))
        yapf_script = os.path.join(depot_tools_dir, "yapf")

        yapf_args = translate_args(args)

        # We must invoke the yapf wrapper via vpython3 so it gets its own env
        vpython_bin = "vpython3"
        if sys.platform == "win32":
            vpython_bin = "vpython3.bat"

        cmd = [vpython_bin, yapf_script] + yapf_args
        return subprocess.call(cmd)


if __name__ == "__main__":
    sys.exit(main())
